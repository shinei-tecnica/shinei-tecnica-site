---
import Base from "@layouts/Base.astro";
import { CTA, COMPANY } from "@config/site.ts";
---
<Base title="送信完了 — 循環・製品化のご相談" tone="entoen" noindex>
  <section class="section">
    <div class="container container--narrow" style="text-align:center;">
      <h1 class="section-title">ご相談を受け付けました</h1>
      <p style="margin-top:var(--space-3); line-height:1.9;">
        {CTA.responseMicrocopy}<br />
        お急ぎの場合は、お電話（<a href={COMPANY.telLink} style="font-weight:700;">{COMPANY.tel}</a>）でもお問い合わせいただけます。
      </p>
      <p style="margin-top:var(--space-4);">
        <a href="/entoen/" class="btn btn--outline">ENTOENトップへ戻る</a>
      </p>
    </div>
  </section>
</Base>
