---
interface Props {
  heading: string;
  items: string[];
  desc: string;
  buttonLabel: string;
  buttonHref: string;
  variant?: "primary" | "secondary";
}

const { heading, items, desc, buttonLabel, buttonHref, variant = "primary" } = Astro.props;
---

<div class:list={["challenges-card", { "challenges-card--secondary": variant === "secondary" }]}>
  <h3 class="challenges-heading">{heading}</h3>

  <ul class="challenges-list">
    {items.map((item) => (
      <li>{item}</li>
    ))}
  </ul>

  <p class="challenges-desc">{desc}</p>

  <a href={buttonHref} class:list={["btn", "btn--primary"]}>
    {buttonLabel}
  </a>
</div>

<style>
  .challenges-card {
    background: var(--c-bg-alt);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .challenges-card--secondary {
    background: rgba(47, 125, 118, 0.05);
    border-color: rgba(47, 125, 118, 0.15);
  }
  .challenges-heading {
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: var(--space-3);
    color: var(--c-navy);
    min-height: 3em;
    display: flex;
    align-items: flex-start;
  }
  .challenges-card--secondary .challenges-heading {
    color: var(--c-entoen);
  }
  .challenges-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-3) 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-height: 6.5em;
  }
  .challenges-list li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 0.95rem;
    color: var(--c-ink);
  }
  .challenges-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--c-navy);
    font-weight: 700;
  }
  .challenges-card--secondary .challenges-list li::before {
    color: var(--c-entoen);
  }
  .challenges-desc {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--c-ink-soft);
    margin-bottom: var(--space-4);
    flex-grow: 1;
    min-height: 5em;
  }
  .challenges-card--secondary .challenges-desc {
    padding-top: 2em;
  }
  .btn {
    align-self: flex-start;
  }
</style>
