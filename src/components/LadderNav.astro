---
// 5段ラダーの視覚化ナビ（金型ハブ・各サービスページの転換動線で使用）
import { LADDER } from "@config/site.ts";
interface Props {
  currentKey?: string;
}
const { currentKey } = Astro.props;
---
<nav class="ladder" aria-label="金型サービスの5段階">
  <ol class="ladder-list">
    {
      LADDER.map((s) => (
        <li class:list={["ladder-item", { "is-current": s.key === currentKey, "is-star": s.star }]}>
          <a href={s.href}>
            <span class="ladder-step">{s.step}</span>
            <span class="ladder-title">{s.title}</span>
          </a>
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .ladder-list {
    display: flex;
    align-items: stretch;
    gap: 0;
    list-style: none;
    padding: 0;
    flex-wrap: wrap;
  }
  .ladder-item {
    flex: 1;
    min-width: 120px;
  }
  .ladder-item a {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.3rem;
    padding: var(--space-2) var(--space-1);
    border: 1px solid var(--c-line);
    border-radius: var(--radius);
    height: 100%;
    transition: border-color 0.2s, background 0.2s;
  }
  .ladder-item a:hover {
    text-decoration: none;
    border-color: var(--c-navy);
    background: rgba(22, 36, 61, 0.03);
  }
  .ladder-item.is-current a {
    border-color: var(--c-navy);
    background: var(--c-navy);
    color: #fff;
  }
  .ladder-item.is-current .ladder-step {
    color: rgba(255, 255, 255, 0.7);
  }
  .ladder-item.is-star .ladder-title::after {
    content: " ★";
    font-size: 0.75em;
  }
  .ladder-step {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--c-navy-300);
    letter-spacing: 0.08em;
  }
  .ladder-title {
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.3;
  }
  @media (max-width: 600px) {
    .ladder-list {
      gap: 0.3rem;
    }
    .ladder-item {
      min-width: calc(50% - 0.3rem);
    }
  }
</style>
