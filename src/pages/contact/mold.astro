---
import Base from "@layouts/Base.astro";
import SectionHeading from "@components/SectionHeading.astro";
import FlowSteps from "@components/FlowSteps.astro";
import { COMPANY, SOCIAL, FORMS, CTA, ANALYTICS } from "@config/site.ts";
---
<Base
  title="金型相談フォーム — 修理・設変・新規金型のご相談"
  description="金型の修理・設計変更・新規製作のご相談はこちらから。写真添付可能。お電話・LINEでもお気軽にご相談ください。"
>
  <section class="section section--alt">
    <div class="container" style="text-align:center; max-width:600px; margin-left:auto; margin-right:auto; padding-block:var(--space-4);">
      <p style="color:var(--c-ink-soft); margin-bottom:var(--space-2);">ご不明な点がございましたら</p>
      <a href="/faq/" style="color:var(--c-navy); font-weight:700; text-decoration:underline;">よくあるご質問（FAQ）をご確認ください</a>
    </div>
  </section>

  <section class="section">
    <div class="container container--narrow">
      <SectionHeading
        en="MOLD CONSULTATION"
        title="金型相談フォーム"
        lead="修理・設変・新規金型のご相談を承ります。写真を添付していただくと、より具体的なご回答が可能です。"
      />

      {/* 電話・LINE */}
      <div class="contact-quick">
        <a href={COMPANY.telLink} class="cq-item" data-ga-event={ANALYTICS.events.telTap}>
          <span class="cq-label">お電話</span>
          <span class="cq-value">{COMPANY.tel}</span>
          <span class="cq-note">{COMPANY.businessHours}</span>
        </a>
        {SOCIAL.line && (
          <a href={SOCIAL.line} class="cq-item" target="_blank" rel="noopener" data-ga-event={ANALYTICS.events.lineTap}>
            <span class="cq-label">LINE</span>
            <span class="cq-value">LINEで相談する</span>
            <span class="cq-note">写真もそのまま送れます</span>
          </a>
        )}
      </div>

      {/* フォーム */}
      <form
        name="mold-consultation"
        method="POST"
        data-netlify="true"
        enctype="multipart/form-data"
        class="form"
        action="/contact/mold/thanks/"
      >
        {FORMS.honeypot && (
          <p class="visually-hidden">
            <label>
              {FORMS.honeypotFieldName}
              <input name={FORMS.honeypotFieldName} />
            </label>
          </p>
        )}
        <input type="hidden" name="form-name" value="mold-consultation" />

        {/* ご相談内容（分類） */}
        <div class="form-group">
          <label class="form-label" for="consultation-category">ご相談内容<span class="form-req">必須</span></label>
          <select name="consultation-category" id="consultation-category" class="form-select" required>
            <option value="">選択してください</option>
            <option value="金型修理">金型修理</option>
            <option value="設計変更（設変）">設計変更（設変）</option>
            <option value="型更新・作り替え">型更新・作り替え</option>
            <option value="新規金型製作">新規金型製作</option>
            <option value="他社製・図面なし対応">他社製・図面なし対応</option>
            <option value="原因特定・改善">原因特定・改善</option>
            <option value="その他">その他</option>
          </select>
        </div>

        {/* 現在の症状 */}
        <fieldset class="form-group">
          <legend class="form-label">現在の症状（複数選択可）</legend>
          <div class="form-checks">
            {["バリ", "ショート", "反り", "離型不良", "ピン折れ", "その他"].map((v) => (
              <label class="form-check">
                <input type="checkbox" name="symptom" value={v} />
                {v}
              </label>
            ))}
          </div>
        </fieldset>

        {/* 現在のお困りごと */}
        <div class="form-group">
          <label class="form-label" for="current-issues">現在のお困りごと</label>
          <textarea name="current-issues" id="current-issues" rows="3" class="form-textarea" placeholder="・図面がなく修理先を探している&#10;・他社製金型の修理を相談したい&#10;・成形不良の原因が分からない"></textarea>
          <p class="form-hint">お困りの状況や背景をお書きください。（任意）</p>
        </div>

        {/* 他社製か */}
        <div class="form-group">
          <label class="form-label" for="third-party">他社製金型ですか？</label>
          <select name="third-party" id="third-party" class="form-select">
            <option value="">選択してください</option>
            <option value="はい">はい</option>
            <option value="いいえ">いいえ</option>
            <option value="不明">不明</option>
          </select>
        </div>

        {/* 図面の有無 */}
        <div class="form-group">
          <label class="form-label" for="drawing">図面の有無</label>
          <select name="drawing" id="drawing" class="form-select">
            <option value="">選択してください</option>
            <option value="あり">あり</option>
            <option value="なし">なし</option>
            <option value="不明">不明</option>
          </select>
        </div>

        {/* 希望時期 */}
        <div class="form-group">
          <label class="form-label" for="timeline">ご希望時期</label>
          <input type="text" name="timeline" id="timeline" class="form-input" placeholder="例：1か月以内、急ぎ、未定 など" />
        </div>

        {/* 流入経路 */}
        <div class="form-group">
          <label class="form-label" for="referral-source">何を見てご相談いただきましたか？</label>
          <select name="referral-source" id="referral-source" class="form-select">
            <option value="">選択してください</option>
            <option value="Google検索">Google検索</option>
            <option value="Googleマップ">Googleマップ</option>
            <option value="Instagram">Instagram</option>
            <option value="紹介">紹介</option>
            <option value="展示会">展示会</option>
            <option value="既存取引">既存取引</option>
            <option value="その他">その他</option>
          </select>
          <p class="form-hint">今後のマーケティング改善の参考にさせていただきます。（任意）</p>
        </div>

        {/* 写真添付 */}
        <div class="form-group">
          <label class="form-label" for="photos">写真・資料の添付</label>
          <input type="file" name="photos" id="photos" accept={FORMS.uploadAccept} multiple class="form-file" />
          <p class="form-hint">{FORMS.uploadNote}</p>
        </div>

        {/* 相談内容 */}
        <div class="form-group">
          <label class="form-label" for="message">ご相談内容の詳細</label>
          <textarea name="message" id="message" rows="5" class="form-textarea" placeholder="金型の状況やお困りごとをお書きください。"></textarea>
        </div>

        <hr style="border:none; border-top:1px solid var(--c-line); margin:var(--space-4) 0;" />

        {/* 連絡先 */}
        <div class="form-group">
          <label class="form-label" for="company-name">会社名</label>
          <input type="text" name="company-name" id="company-name" class="form-input" />
        </div>
        <div class="form-group">
          <label class="form-label" for="contact-name">お名前 <span class="form-req">必須</span></label>
          <input type="text" name="contact-name" id="contact-name" required class="form-input" />
        </div>
        <div class="form-group">
          <label class="form-label" for="email">メールアドレス <span class="form-req">必須</span></label>
          <input type="email" name="email" id="email" required class="form-input" />
        </div>
        <div class="form-group">
          <label class="form-label" for="phone">電話番号</label>
          <input type="tel" name="phone" id="phone" class="form-input" />
        </div>

        <p class="form-privacy">
          <a href="/privacy/" target="_blank">プライバシーポリシー</a>をご確認のうえ、送信してください。
        </p>

        <button type="submit" class="btn btn--primary btn--lg form-submit">
          {CTA.moldSecondaryLabel}
        </button>
      </form>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionHeading en="FLOW" title="ご相談の流れ" />
      <FlowSteps />
    </div>
  </section>
</Base>

<style>
  .contact-quick {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }
  .cq-item {
    flex: 1;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-lg);
    text-align: center;
    transition: border-color 0.2s;
  }
  .cq-item:hover {
    text-decoration: none;
    border-color: var(--c-navy);
  }
  .cq-label {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--c-navy-300);
    letter-spacing: 0.08em;
  }
  .cq-value {
    font-size: 1.2rem;
    font-weight: 700;
  }
  .cq-note {
    font-size: 0.78rem;
    color: var(--c-ink-soft);
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-label {
    font-weight: 700;
    font-size: 0.95rem;
  }
  .form-req {
    font-size: 0.75rem;
    color: #c44;
    margin-left: 0.3em;
  }
  .form-input,
  .form-select,
  .form-textarea {
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--c-line);
    border-radius: var(--radius);
    font: inherit;
    font-size: 1rem;
    width: 100%;
  }
  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: 2px solid var(--c-navy);
    outline-offset: 1px;
    border-color: var(--c-navy);
  }
  .form-file {
    font: inherit;
  }
  .form-hint {
    font-size: 0.8rem;
    color: var(--c-ink-soft);
  }
  .form-checks {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }
  .form-check {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.95rem;
    cursor: pointer;
  }
  .form-check input {
    width: 18px;
    height: 18px;
    cursor: pointer;
  }
  .form-privacy {
    font-size: 0.85rem;
    color: var(--c-ink-soft);
  }
  .form-privacy a {
    text-decoration: underline;
    color: var(--c-navy);
  }
  .form-submit {
    align-self: center;
    width: 100%;
    max-width: 360px;
    justify-content: center;
  }
</style>
