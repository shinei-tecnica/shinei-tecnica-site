---
import Base from "@layouts/Base.astro";
import { CTA } from "@config/site.ts";

const faqs = [
  {
    category: "金型修理について",
    items: [
      {
        q: "他社製金型も修理できますか？",
        a: "対応可能です。製作メーカーに関わらず、現品確認のうえ対応いたします。"
      },
      {
        q: "海外製金型も対応できますか？",
        a: "中国製をはじめ海外調達金型の修理・設計変更にも対応しています。"
      },
      {
        q: "図面がなくても対応できますか？",
        a: "現品確認・採寸により対応可能なケースがあります。まずは写真をお送りください。"
      },
      {
        q: "写真だけで相談できますか？",
        a: "概算判断は可能です。詳細なお見積りは現物確認後となります。"
      },
      {
        q: "修理と型更新、どちらが良いか判断できません。",
        a: "金型の状態を確認し、修理・設変・型更新の中から最適な方法をご提案します。"
      }
    ]
  },
  {
    category: "設計変更（設変）について",
    items: [
      {
        q: "仕様変更による設変は可能ですか？",
        a: "対応可能です。現状の金型構造を確認したうえでご提案します。"
      },
      {
        q: "量産中の金型でも対応できますか？",
        a: "対応可能です。生産スケジュールを考慮しながら進めます。"
      }
    ]
  },
  {
    category: "新規金型について",
    items: [
      {
        q: "新規金型製作のみの相談も可能ですか？",
        a: "対応可能です。量産条件や成形品情報を確認しご提案します。"
      },
      {
        q: "成形やトライも依頼できますか？",
        a: "協力成形工場と連携して対応しています。"
      }
    ]
  },
  {
    category: "メンテナンス・予防保全について",
    items: [
      {
        q: "定期点検だけ依頼できますか？",
        a: "可能です。摩耗や破損リスクの確認を行います。"
      },
      {
        q: "型更新の時期を相談できますか？",
        a: "金型状態を確認したうえでご提案します。"
      }
    ]
  }
];
---

<Base
  title="よくあるご質問（FAQ）｜プラスチック射出成形金型"
  description="プラスチック射出成形金型の修理、設計変更、型更新、新規製作に関するよくあるご質問。他社製金型、海外製金型、図面がない金型への対応についても掲載。"
>
  <section class="section">
    <div class="container container--narrow">
      <p style="font-size:0.85rem; letter-spacing:0.2em; color:var(--c-navy-300); font-weight:600; margin-bottom:var(--space-2);">FREQUENTLY ASKED QUESTIONS</p>
      <h1 style="font-size:clamp(1.8rem,5vw,2.4rem); font-weight:900; line-height:1.3; color:var(--c-navy); margin-bottom:var(--space-4);">
        よくあるご質問
      </h1>
      <p style="font-size:1rem; line-height:1.8; color:var(--c-ink); margin-bottom:var(--space-3);">
        お問い合わせ前によくいただくご質問をまとめました。
      </p>
      <p style="font-size:1rem; line-height:1.8; color:var(--c-ink); margin-bottom:0;">
        他社製金型、図面が残っていない金型、海外製金型のご相談も対応しています。
        <br />
        ご不明な点がございましたら、お気軽にご相談ください。
      </p>
    </div>
  </section>

  {faqs.map((category) => (
    <section class="section section--alt">
      <div class="container container--narrow">
        <h2 style="font-size:1.4rem; font-weight:700; margin-bottom:var(--space-4); color:var(--c-navy);">
          {category.category}
        </h2>

        <div class="faq-list">
          {category.items.map((item, idx) => (
            <div class="faq-item" style={`border-bottom: ${idx < category.items.length - 1 ? '1px solid var(--c-line)' : 'none'}`}>
              <h3 style="font-weight:700; font-size:1rem; margin-bottom:var(--space-2); color:var(--c-navy);">
                <span style="font-weight:700; color:var(--c-navy); margin-right:0.8rem;">Q.</span>
                {item.q}
              </h3>
              <p style="font-size:0.95rem; line-height:1.7; color:var(--c-ink); margin-left:2.4rem;">
                <span style="font-weight:700; color:var(--c-navy); margin-right:0.8rem; display:inline-block;">A.</span>
                {item.a}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="section">
    <div class="container">
      <div style="text-align:center; max-width:600px; margin:0 auto;">
        <p style="font-size:1.1rem; color:var(--c-ink); margin-bottom:var(--space-3);">
          ご不明な点がある場合はお気軽にご相談ください。
        </p>
        <div style="display:flex; gap:var(--space-2); justify-content:center; flex-wrap:wrap;">
          <a href={CTA.moldFormHref} class="btn btn--primary">
            写真を送って相談する
          </a>
          <a href="tel:+81532851345" class="btn btn--outline">
            電話で相談する
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .faq-item {
    padding: var(--space-3) 0;
  }
</style>
